{
	"name": "fundid",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:cf": "wrangler pages dev --r2 ITEM_IMAGES=fundid-item-images --kv RATE_LIMIT -- pnpm dev",
		"build": "vite build",
		"deploy": "vite build && wrangler pages deploy .svelte-kit/cloudflare --project-name fundid --branch main",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@tolgee/cli": "^2.16.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"wrangler": "^4.78.0"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.100.0",
		"@tolgee/svelte": "^7.0.0",
		"browser-image-compression": "^2.0.2",
		"exifr": "^7.1.3",
		"lucide-svelte": "0.475.0",
		"maplibre-gl": "^5.21.0",
		"posthog-js": "^1.364.1"
	}
}
